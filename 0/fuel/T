FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0/fuel";
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
#include "$FOAM_CASE/constant/initialConditions"

dimensions      [0 0 0 1 0 0 0];

internalField   uniform $Tfuel; // K

boundaryField
{
    wall-fuel
    {
        type            zeroGradient;
    }
    contact_region-trg
    {
        type            compressible::turbulentTemperatureRadCoupledMixed;
        Tnbr            T;
        kappaMethod     solidThermo;
        value           $internalField;
    }
    contact_region_2-trg
    {
        type            compressible::turbulentTemperatureRadCoupledMixed;
        Tnbr            T;
        kappaMethod     solidThermo;
        value           $internalField;
    }
    contact_region_3-trg
    {
        type            compressible::turbulentTemperatureRadCoupledMixed;
        Tnbr            T;
        kappaMethod     solidThermo;
        value           $internalField;
    }
    fuel_to_gap
    {
        type            compressible::turbulentTemperatureRadCoupledMixed;
        Tnbr            T;
        kappaMethod     solidThermo;
        value           $internalField;
    }
}


