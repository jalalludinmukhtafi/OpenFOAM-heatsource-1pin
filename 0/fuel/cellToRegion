FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0/fuel";
    object      cellToRegion;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 0 0 0 0];

internalField   uniform 1;

boundaryField
{
    wall-fuel
    {
        type            zeroGradient;
    }
    contact_region-trg
    {
        type            zeroGradient;
    }
    contact_region_2-trg
    {
        type            zeroGradient;
    }
    contact_region_3-trg
    {
        type            zeroGradient;
    }
    fuel_to_gap
    {
        type            calculated;
        value           uniform 0;
    }
}


