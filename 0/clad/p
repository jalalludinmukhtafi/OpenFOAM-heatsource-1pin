FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0/fuel";
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
#include "$FOAM_CASE/constant/initialConditions"
dimensions      [1 -1 -2 0 0 0 0];
internalField   uniform $pInitial;

boundaryField
{
    wall-clad
    {
        type            zeroGradient;
    }
    clad_to_gap
    {
        type            zeroGradient;
    }
    clad_to_argon
    {
        type            zeroGradient;
    }
    clad_to_coolant
    {
        type            zeroGradient;
    }
}

