FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0/fuel";
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

#include "$FOAM_CASE/constant/initialConditions"
dimensions      [1 -1 -2 0 0 0 0];
internalField   uniform $pInitial;
outletPressure	uniform $pOutlet;

boundaryField
{	
    wall-argon
    {
        type            zeroGradient;
    }
    argon_to_clad
    {
        type            calculated;
		value			$internalField;
    }
}


