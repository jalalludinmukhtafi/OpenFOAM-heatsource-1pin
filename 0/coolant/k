FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0/fuel";
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 0.5;

boundaryField
{		
    wall-coolant
    {
        type            zeroGradient;
    }
    inlet
    {
        type            fixedValue;
        value           uniform 0.1;
    }
    outlet
    {
		type            inletOutlet;
		inletValue      uniform 0.1;
		value           uniform 0.1;
    }
    reflective
    {
        type            symmetry;
    }
    coolant_to_clad
    {
        type            zeroGradient;
    }
}


