FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volVectorField;
    location    "0/fuel";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (0 -3 0);

boundaryField
{	
    wall-coolant
    {
        type            zeroGradient;
    }
    inlet
    {
        type            pressureInletVelocity;
		value			uniform (0 -3 0);
    }
    outlet
    {
        type            pressureInletOutletVelocity;
		value			uniform (0 -3 0);
    }
    reflective
    {
        type            symmetry;
    }
    coolant_to_clad
    {
        type            noSlip;
    }
}


