FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0/fuel";
    object      epsilon;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -3 0 0 0 0];

internalField   uniform 1;

boundaryField
{	
    wall-gap
    {
        type            zeroGradient;
    }
    contact_region-src
    {
         type            zeroGradient;
    }
    contact_region_2-src
    {
        type            zeroGradient;
    }
    contact_region_3-src
    {
        type            zeroGradient;
    }
    gap_to_clad
    {
        type            zeroGradient;
    }
    gap_to_fuel
    {
        type            zeroGradient;
    }

}


