FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0/fuel";
    object      alphat;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -1 -1 0 0 0 0];

internalField   uniform 0;

boundaryField
{	
    wall-gap
    {
        type            zeroGradient;
    }
    contact_region-src
    {
        type            compressible::alphatWallFunction;
        value           uniform 0;
    }
    contact_region_2-src
    {
        type            compressible::alphatWallFunction;
        value           uniform 0;
    }
    contact_region_3-src
    {
        type            compressible::alphatWallFunction;
        value           uniform 0;
    }
    gap_to_clad
    {
        type            compressible::alphatWallFunction;
        value           uniform 0;
    }
    gap_to_fuel
    {
        type            compressible::alphatWallFunction;
        value           uniform 0;
    }
}


