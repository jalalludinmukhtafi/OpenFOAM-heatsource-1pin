FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      thermophysicalProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

thermoType
{
    type            heSolidThermo;
    mixture         pureMixture;
    transport       constIso;
    thermo          hConst;
    equationOfState rhoConst;
    specie          specie;
    energy          sensibleEnthalpy;
}
mixture // AISI 316L, pakai data at 20C 
{
    specie
    {
        nMoles      1;
        molWeight   56.4;   // [g/mol]
    }
    transport
    {
        kappa   15;
    }
    thermodynamics
    {
        Hf      0;
        Cp      500; 
    }
    equationOfState
    {
        rho         8000; // kg/m3
    }
}


