FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      thermophysicalProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

thermoType
{
    type            heRhoThermo;
    mixture         pureMixture;
    transport       const;
    thermo          hConst;
    equationOfState perfectGas;
    specie          specie;
    energy          sensibleEnthalpy;
}

mixture // argon database NIST
{
    specie
    {
        nMoles      1;
        molWeight   39.948; // g/mol
    }
    thermodynamics
    {
        Hf          0; //[J/kg]
        Cp          535.34;
    }
    transport
    {
        mu          3.5731e-05; // Pa.S
        Pr          0.66;
    }
}


